<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="FEN-Bloat"
        MinWidth="900" MinHeight="600"
        Width="1050" Height="680"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource BgColor}"
        Foreground="{DynamicResource FgColor}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="5" CaptionHeight="32" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="MainBorder" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource BgColor}" Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" x:Name="TitleBar">
                <Border x:Name="TitleBarBackground" Background="{DynamicResource BgColor}" CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo area -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0">
                            <Image x:Name="LogoImage" Width="22" Height="22" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="FEN-Bloat" Foreground="{DynamicResource FgColor}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="VersionText" Text=" v1.0.0" Foreground="{DynamicResource FgColor}" VerticalAlignment="Center" FontSize="11" Opacity="0.6"/>
                        </StackPanel>

                        <!-- Title bar buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="ThemeToggleBtn" shell:WindowChrome.IsHitTestVisibleInChrome="True" Content="&#xE790;" FontFamily="Segoe Fluent Icons" FontSize="13" Style="{StaticResource TitlebarButton}" ToolTip="Toggle theme"/>
                            <Button x:Name="CloseBtn" shell:WindowChrome.IsHitTestVisibleInChrome="True" Content="&#xE8BB;" Style="{StaticResource CloseButton}" ToolTip="Close"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1" x:Name="ContentGrid">
                <!-- Tab Control with custom styled headers -->
                <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0" Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border" Background="Transparent" BorderThickness="0" Padding="16,10" Margin="0,0,0,0" CornerRadius="0">
                                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.FontSize="13" TextElement.FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource FgColor}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SecondaryButtonHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- ==================== TAB: Install ==================== -->
                    <TabItem Header="Install" x:Name="TabInstall">
                        <Grid Margin="0,0,0,48">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="24,16,24,8">
                                <TextBlock Text="Install &amp; Remove Apps" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource FgColor}"/>
                                <TextBlock Text="Install software or remove pre-installed bloatware" FontSize="13" Foreground="{DynamicResource FgColor}" Opacity="0.7" Margin="0,2,0,8"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,0,24,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0 -->
                                    <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Essentials" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallEssentialsPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE90F;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Utilities" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallUtilitiesPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Grid.Row="0" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Gaming &amp; Xbox" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallGamingPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Row 1 -->
                                    <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE97F;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Dev Tools" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallDevPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Creative &amp; Media" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallCreativePanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Grid.Row="1" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Social &amp; Communication" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallSocialPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Row 2 -->
                                    <Border Grid.Column="0" Grid.Row="2" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE770;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Microsoft Apps" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallMicrosoftPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Grid.Row="2" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE918;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Productivity &amp; Cloud" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallProductivityPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Grid.Row="2" Style="{StaticResource CategoryCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <TextBlock Text="Games" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="InstallGamesPanel" Orientation="Vertical"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>

                            <Border Grid.Row="2" Background="{DynamicResource CardBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="24,12">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="InstallUpgradeBtn" Style="{StaticResource PrimaryButtonStyle}" Width="210" Height="40" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Install / Upgrade Apps" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="InstallUpdateAllBtn" Style="{StaticResource WarningButtonStyle}" Width="140" Height="40" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Upgrade All" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="UninstallAppsBtn" Style="{StaticResource DangerButtonStyle}" Width="170" Height="40" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Uninstall Selected" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="InstallRemoveBtn" Style="{StaticResource SecondaryButtonStyle}" Width="180" Height="40" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Remove Needless Apps" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="InstallUnselectAllBtn" Style="{StaticResource SecondaryButtonStyle}" Width="130" Height="40" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Unselect All" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock x:Name="InstallStatusText" Text="" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{DynamicResource FgColor}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ==================== TAB: Tweaks ==================== -->
                    <TabItem Header="Tweaks" x:Name="TabTweaks">
                        <Grid Margin="0,0,0,48">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="24,16,24,8">
                                <TextBlock Text="Tweaks" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource FgColor}"/>
                                <TextBlock Text="Privacy, AI, System and UI customizations" FontSize="13" Foreground="{DynamicResource FgColor}" Opacity="0.7" Margin="0,2,0,8"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24,0,24,0">
                                <StackPanel>
                                    <WrapPanel>
                                        <!-- Privacy & AI -->
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="19" Foreground="{DynamicResource FgColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Privacy &amp; AI" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                                </StackPanel>
                                                <StackPanel x:Name="PrivacyAIPanel" Orientation="Vertical"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- System & UI -->
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE770;" FontFamily="Segoe Fluent Icons" FontSize="19" Foreground="{DynamicResource FgColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="System &amp; UI" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                                </StackPanel>
                                                <StackPanel x:Name="SystemUIPanel" Orientation="Vertical"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Notifications & Taskbar -->
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe Fluent Icons" FontSize="19" Foreground="{DynamicResource FgColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Notifications &amp; Taskbar" Style="{StaticResource CategoryHeaderTextBlock}"/>
                                                </StackPanel>
                                                <StackPanel x:Name="NotifTaskbarPanel" Orientation="Vertical"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="2" Background="{DynamicResource CardBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="24,12">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="TweaksRecommendedBtn" Style="{StaticResource SecondaryButtonStyle}" Width="140" Height="40" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE932;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Recommended" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="TweaksSelectAllBtn" Style="{StaticResource SecondaryButtonStyle}" Width="120" Height="40" Margin="8,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE934;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Select All" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="TweaksUnselectAllBtn" Style="{StaticResource SecondaryButtonStyle}" Width="120" Height="40" Margin="8,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE935;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Unselect All" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="TweaksApplyBtn" Style="{StaticResource PrimaryButtonStyle}" Width="160" Height="40" Margin="12,0,0,0" FontSize="15">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Apply Selected" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock x:Name="TweaksStatusText" Text="" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{DynamicResource FgColor}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ==================== TAB: Tools ==================== -->
                    <TabItem Header="Tools" x:Name="TabTools">
                        <Grid Margin="0,0,0,48">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="24,16,24,8">
                                <TextBlock Text="Tools" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource FgColor}"/>
                                <TextBlock Text="System maintenance and repair utilities" FontSize="13" Foreground="{DynamicResource FgColor}" Opacity="0.7" Margin="0,2,0,8"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24,0,24,0">
                                <StackPanel>
                                    <WrapPanel>
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <Button x:Name="ToolRepairWU" Style="{StaticResource SecondaryButtonStyle}" Width="268" Height="50" FontSize="14" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE770;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Repair Windows Update" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <Button x:Name="ToolSFC" Style="{StaticResource SecondaryButtonStyle}" Width="268" Height="50" FontSize="14" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Run SFC &amp; DISM" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <Button x:Name="ToolCleanTemp" Style="{StaticResource SecondaryButtonStyle}" Width="268" Height="50" FontSize="14" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Clean Temporary Files" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <Button x:Name="ToolRestorePoint" Style="{StaticResource SecondaryButtonStyle}" Width="268" Height="50" FontSize="14" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Create Restore Point" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <Button x:Name="ToolMicroWin" Style="{StaticResource SecondaryButtonStyle}" Width="268" Height="50" FontSize="14" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="MicroWin (ISO Creator)" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                        <Border Style="{StaticResource CategoryCardBorderStyle}" Width="300">
                                            <Button x:Name="ToolOpenLogs" Style="{StaticResource SecondaryButtonStyle}" Width="268" Height="50" FontSize="14" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xF000;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Open Logs Folder" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- Progress Bar at bottom of content -->
                <ProgressBar x:Name="MainProgressBar" Grid.Row="1" Height="3" VerticalAlignment="Bottom" Style="{StaticResource ApplyProgressBarStyle}" Visibility="Hidden"/>
            </Grid>
        </Grid>
    </Border>
</Window>
